# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend
APP_ENV=development
LOG_LEVEL=INFO
WORKFLOW_STUDIO_DB=server/data/workflow_studio.db
# Optional. When set, this overrides WORKFLOW_STUDIO_DB.
DATABASE_URL=sqlite:///server/data/workflow_studio.db
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional model providers
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=

# Optional external RAG provider: PaiSmart
EXTERNAL_RAG_ENABLED=false
PAISMART_BASE_URL=http://127.0.0.1:8080
PAISMART_TOKEN=
PAISMART_TIMEOUT_SECONDS=12

# Used to protect workspace-level model API keys in local storage.
# Change this before sharing a database between machines.
MODEL_CONFIG_SECRET=workflow-studio-local-model-config-secret

# Async run queue.
# Local beginner mode: thread
# Production compose mode: redis
# Durable fallback without Redis: database
RUN_JOB_QUEUE_BACKEND=thread
RUN_JOB_WORKERS=2
RUN_JOB_POLL_INTERVAL_SECONDS=1
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_RUN_JOB_QUEUE=workflow-studio:run-jobs

# Docker Compose PostgreSQL defaults. Change passwords before exposing services.
POSTGRES_DB=workflow_studio
POSTGRES_USER=workflow_studio
POSTGRES_PASSWORD=workflow_studio_dev_password
