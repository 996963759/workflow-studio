# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend
APP_ENV=development
# demo/development allow simulated results but mark the run as degraded.
# production rejects every simulated or failed-provider fallback.
RUN_EXECUTION_MODE=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://workflow_studio:workflow_studio_dev_password@127.0.0.1:5432/workflow_studio
TEST_DATABASE_URL=postgresql+psycopg://workflow_studio:workflow_studio_dev_password@127.0.0.1:5432/workflow_studio_test
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
REDIS_URL=
REDIS_SOCKET_TIMEOUT_SECONDS=0.2
ADMIN_OVERVIEW_CACHE_TTL_SECONDS=20

# Optional model providers
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=

# Optional company MCP Gateway (Streamable HTTP).
# Authorization can contain the complete value (for example "Bearer ...").
# API keys generated by the company MCP Gateway are sent as X-API-Key.
MCP_GATEWAY_URL=
MCP_GATEWAY_TIMEOUT_SECONDS=30
MCP_GATEWAY_AUTHORIZATION=
MCP_GATEWAY_TOKEN=
MCP_GATEWAY_API_KEY=
# Optional override for tools whose schema explicitly requires a token argument.
# If empty, MCP_GATEWAY_AUTHORIZATION / MCP_GATEWAY_TOKEN is reused.
MCP_TOOL_TOKEN=
MCP_PROJECT_ID=
MCP_TENANT_CODE=
MCP_USER_ID=

# Optional Alibaba Cloud Model Studio / DashScope providers.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_TIMEOUT_SECONDS=60
DASHSCOPE_MAX_POLL_SECONDS=90
ALIYUN_TTS_MODEL=cosyvoice-v2
ALIYUN_IMAGE_MODEL=wanx2.1-t2i-turbo

# Optional external RAG provider: PaiSmart
EXTERNAL_RAG_ENABLED=false
PAISMART_BASE_URL=http://127.0.0.1:8080
PAISMART_TOKEN=
PAISMART_TIMEOUT_SECONDS=12

# Used to protect workspace-level model API keys in local storage.
# Change this before sharing a database between machines.
MODEL_CONFIG_SECRET=workflow-studio-local-model-config-secret
SESSION_TTL_HOURS=168
WORKSPACE_INVITATION_TTL_HOURS=168

# Async run queue.
# Formal async runs use Kafka. Tests can override this to thread.
RUN_JOB_QUEUE_BACKEND=kafka
RUN_JOB_WORKERS=2
RUN_JOB_POLL_INTERVAL_SECONDS=1
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_RUN_JOB_TOPIC=workflow-studio-run-jobs
KAFKA_CONSUMER_GROUP=workflow-studio-workers
KAFKA_POLL_TIMEOUT_MS=2000

# Docker Compose PostgreSQL defaults. Change passwords before exposing services.
POSTGRES_DB=workflow_studio
POSTGRES_USER=workflow_studio
POSTGRES_PASSWORD=workflow_studio_dev_password
POSTGRES_PORT=5432
REDIS_PORT=6379
